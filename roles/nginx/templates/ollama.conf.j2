map $http_authorization $auth_ok {
    default 0;
    "Bearer {{ ollama_token }}" 1;
}

server {
    listen 80;
    server_name ollama.aperosbros.net;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name ollama.aperosbros.net;
    listen 11435 ssl;

    ssl_certificate /etc/letsencrypt/live/aperosbros.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/aperosbros.net/privkey.pem;

    location / {
        if ($auth_ok != 1) {
            return 401;
        }
        proxy_pass http://127.0.0.1:11434;
        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
    }
}
