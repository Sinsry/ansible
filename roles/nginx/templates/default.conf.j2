server {
    listen 443 ssl default_server;
    server_name *.aperosbros.net;

    ssl_certificate /etc/letsencrypt/live/aperosbros.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/aperosbros.net/privkey.pem;

    root /var/www/aperosbros;

    location / {
        try_files $uri $uri/ /index.html;
    }
}
